# Semgrep 忽略文件
# 格式与 .gitignore 相同

# 依赖目录
node_modules/
**/node_modules/**

# 构建输出
dist/
**/dist/**
build/
**/build/**
out/
**/out/**

# 测试覆盖率
coverage/
**/coverage/**

# 锁文件
**/package-lock.json
**/pnpm-lock.yaml
**/yarn.lock

# 类型声明
**/*.tsbuildinfo

# 编译输出
**/*.min.js
**/*.bundle.js

# 测试文件
**/*.test.ts
**/*.spec.ts
**/__tests__/**
**/tests/**
**/test/**

# 示例文件
**/examples/**

# 文档
**/docs/api/**
**/.vitepress/**

# VS Code
**/.vscode/**
**/.vscode-test/**

# 其他
**/*.html
**/*.vsix
