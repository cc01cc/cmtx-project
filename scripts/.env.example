# OSS 文档上传配置示例
# 复制此文件为 .env，然后填入你的实际配置
# .env 文件应该被添加到 .gitignore（不要提交到版本控制）

# 阿里云 OSS 配置
ALIYUN_OSS_PROFILE=cmtx
ALIYUN_OSS_BUCKET=your-bucket-name
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# 文档路径配置（可选）
ALIYUN_OSS_DOC_PATH=cmtx
ALIYUN_OSS_CORE_PATH=cmtx/core
ALIYUN_OSS_UPLOAD_PATH=cmtx/upload

# 访问地址配置（可选）
DOC_SITE_URL=https://your-domain.com
