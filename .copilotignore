**/.vitepress/cache
.docusaurus
.cache
.parcel-cache
.svelte-kit/

# Generated documentation (TypeDoc generates dist/docs/api)
**/docs/api/

# Testing & coverage
coverage/
*.lcov
.nyc_output
.test-*/
.trash/

# Environment & secrets
.env
.env.*
!.env.example

