{
    "$schema": "https://opencode.ai/config.json",
    "instructions": ["AGENTS.md", "docs/ARCHITECTURE.md", "docs/CODING-STANDARDS.md"],
    "plugin": ["@mohak34/opencode-notifier@latest"],
    "agent": {},
    "provider": {
        "bailian-coding-plan": {
            "npm": "@ai-sdk/anthropic",
            "name": "Model Studio Coding Plan",
            "options": {
                "baseURL": "https://coding.dashscope.aliyuncs.com/apps/anthropic/v1",
                "apiKey": "{env:OPENCODE_BAILIAN_API_KEY}"
            },
            "models": {
                "qwen3.5-plus": {
                    "name": "Qwen3.5 Plus",
                    "modalities": {
                        "input": ["text", "image"],
                        "output": ["text"]
                    },
                    "options": {
                        "thinking": {
                            "type": "enabled",
                            "budgetTokens": 1024
                        }
                    }
                },
                "qwen3-max-2026-01-23": {
                    "name": "Qwen3 Max 2026-01-23"
                },
                "qwen3-coder-next": {
                    "name": "Qwen3 Coder Next"
                },
                "qwen3-coder-plus": {
                    "name": "Qwen3 Coder Plus"
                },
                "MiniMax-M2.5": {
                    "name": "MiniMax M2.5",
                    "options": {
                        "thinking": {
                            "type": "enabled",
                            "budgetTokens": 1024
                        }
                    }
                },
                "glm-5": {
                    "name": "GLM-5",
                    "options": {
                        "thinking": {
                            "type": "enabled",
                            "budgetTokens": 1024
                        }
                    }
                },
                "glm-4.7": {
                    "name": "GLM-4.7",
                    "options": {
                        "thinking": {
                            "type": "enabled",
                            "budgetTokens": 1024
                        }
                    }
                },
                "kimi-k2.5": {
                    "name": "Kimi K2.5",
                    "modalities": {
                        "input": ["text", "image"],
                        "output": ["text"]
                    },
                    "options": {
                        "thinking": {
                            "type": "enabled",
                            "budgetTokens": 1024
                        }
                    }
                }
            }
        },
        "ark-coding-plan": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "volcengine",
            "options": {
                "baseURL": "https://ark.cn-beijing.volces.com/api/coding/v3",
                "apiKey": "{env:OPENCODE_VOLCENGINE_API_KEY}"
            },
            "models": {
                "ark-code-latest": {
                    "name": "ark-code-latest"
                },
                "kimi-k2.5": {
                    "name": "kimi-k2.5",
                    "modalities": {
                        "input": ["text", "image"],
                        "output": ["text"]
                    },
                    "options": {
                        "thinking": {
                            "type": "enabled"
                        }
                    }
                },
                "doubao-seed-2.0-code": {
                    "name": "doubao-seed-2.0-code",
                    "modalities": {
                        "input": ["text"],
                        "output": ["text"]
                    },
                    "options": {
                        "thinking": {
                            "type": "enabled"
                        }
                    }
                },
                "doubao-seed-code": {
                    "name": "doubao-seed-code",
                    "modalities": {
                        "input": ["text"],
                        "output": ["text"]
                    },
                    "options": {
                        "thinking": {
                            "type": "enabled"
                        }
                    }
                },
                "glm-4.7": {
                    "name": "glm-4.7",
                    "modalities": {
                        "input": ["text"],
                        "output": ["text"]
                    },
                    "options": {
                        "thinking": {
                            "type": "enabled"
                        }
                    }
                },
                "deepseek-v3.2": {
                    "name": "deepseek-v3.2",
                    "modalities": {
                        "input": ["text"],
                        "output": ["text"]
                    },
                    "options": {
                        "thinking": {
                            "type": "enabled"
                        }
                    }
                }
            }
        }
    },
    "mcp": {
        "WebSearch": {
            "type": "remote",
            "url": "https://dashscope.aliyuncs.com/api/v1/mcps/WebSearch/sse",
            "headers": {
                "Authorization": "Bearer {env:DASHSCOPE_MCP_API_KEY}"
            }
        },
        "WebParser": {
            "type": "remote",
            "url": "https://dashscope.aliyuncs.com/api/v1/mcps/WebParser/sse",
            "headers": {
                "Authorization": "Bearer {env:DASHSCOPE_MCP_API_KEY}"
            }
        },
        "tavily-search": {
            "type": "remote",
            "url": "https://mcp.tavily.com/mcp/?tavilyApiKey={env:TAVILY_API_KEY}"
        },
        "sequentialthinking": {
            "type": "local",
            "command": ["pnpm", "dlx", "@modelcontextprotocol/server-sequential-thinking"],
            "enabled": true
        },
        "context7": {
            "type": "local",
            "command": [
                "pnpm",
                "dlx",
                "@upstash/context7-mcp",
                "--api-key",
                "{env:CONTEXT7_API_KEY}"
            ],
            "enabled": true
        },
        "time": {
            "type": "local",
            "command": ["uvx", "mcp-server-time"],
            "enabled": true
        },
        "memory": {
            "type": "local",
            "command": ["pnpm", "dlx", "@modelcontextprotocol/server-memory"],
            "enabled": true
        },
        "filesystem": {
            "type": "local",
            "command": ["pnpm", "dlx", "@modelcontextprotocol/server-filesystem", "."],
            "enabled": true
        },
        "git": {
            "type": "local",
            "command": ["uvx", "mcp-server-git", "--repository", "."],
            "enabled": true
        },
        "puppeteer": {
            "type": "local",
            "command": ["pnpm", "dlx", "@modelcontextprotocol/server-puppeteer"],
            "enabled": true
        },
        "gh_grep": {
            "type": "remote",
            "url": "https://mcp.grep.app"
        }
    }
}
