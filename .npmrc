shared-workspace-lockfile=true
prefer-workspace-packages=true
save-exact=true
# pnpm configuration for cmtx monorepo

# Hoist dependencies to root node_modules for better compatibility
# shamefully-hoist=true

# Allow missing peer dependencies (useful for packages with optional peer deps)
strict-peer-dependencies=false

# Use exact versions from lockfile
prefer-frozen-lockfile=true

# Set pnpm store directory to the shared volume path
# store-dir=/pnpm-store

# Public scope packages should be published publicly by default
# publishConfig.access is set to "public" in package.json for scoped packages

# Automatically install peer dependencies when installing a package
auto-install-peers=true