{
    "name": "@cmtx/fpe-wasm",
    "version": "0.1.1-alpha.2",
    "description": "NIST SP 800-38G FF1 format-preserving encryption (WASM)",
    "keywords": [
        "cmtx",
        "encryption",
        "ff1",
        "format-preserving",
        "fpe",
        "nist",
        "wasm"
    ],
    "homepage": "https://github.com/cc01cc/cmtx-project/tree/main/packages/fpe-wasm",
    "bugs": {
        "url": "https://github.com/cc01cc/cmtx-project/issues"
    },
    "license": "Apache-2.0",
    "author": "cc01cc",
    "repository": {
        "type": "git",
        "url": "https://github.com/cc01cc/cmtx-project.git",
        "directory": "packages/fpe-wasm"
    },
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md"
    ],
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build:wasm": "wasm-pack build --target web --out-dir pkg",
        "build": "pnpm run build:wasm && tsdown",
        "build:watch": "tsdown --watch",
        "build:release": "wasm-pack build --target web --out-dir pkg --release && tsdown",
        "test:wasm": "wasm-pack test --node",
        "test:ts": "vitest run",
        "test": "pnpm run test:wasm && pnpm run test:ts",
        "docs": "typedoc",
        "docs:rust": "cargo doc --no-deps",
        "clean": "rm -rf dist",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "typecheck:tests": "tsc --noEmit -p tsconfig.test.json"
    },
    "devDependencies": {
        "@types/node": "^25.2.1",
        "typescript": "^6.0.3",
        "vitest": "^4.0.18"
    },
    "engines": {
        "node": ">=22.0.0"
    }
}
