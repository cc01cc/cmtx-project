{
    "name": "@cmtx/asset",
    "version": "0.2.0-alpha.3",
    "description": "Markdown asset management for cmtx - 支持本地图片上传和远程图片转移",
    "keywords": [
        "asset",
        "cmtx",
        "image",
        "markdown",
        "transfer",
        "upload"
    ],
    "homepage": "https://github.com/cc01cc/cmtx-project",
    "bugs": {
        "url": "https://github.com/cc01cc/cmtx-project/issues"
    },
    "license": "Apache-2.0",
    "author": "cc01cc",
    "repository": {
        "type": "git",
        "url": "https://github.com/cc01cc/cmtx-project.git",
        "directory": "packages/asset"
    },
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md"
    ],
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./download": {
            "types": "./dist/download.d.mts",
            "import": "./dist/download.mjs",
            "require": "./dist/download.cjs"
        },
        "./upload": {
            "types": "./dist/upload.d.mts",
            "import": "./dist/upload.mjs",
            "require": "./dist/upload.cjs"
        },
        "./transfer": {
            "types": "./dist/transfer.d.mts",
            "import": "./dist/transfer.mjs",
            "require": "./dist/transfer.cjs"
        },
        "./shared": {
            "types": "./dist/shared.d.mts",
            "import": "./dist/shared.mjs",
            "require": "./dist/shared.cjs"
        },
        "./config": {
            "types": "./dist/config.d.mts",
            "import": "./dist/config.mjs",
            "require": "./dist/config.cjs"
        },
        "./config/schema": {
            "import": "./dist/config/cmtx.schema.json",
            "require": "./dist/config/cmtx.schema.json"
        },
        "./file": {
            "types": "./dist/file.d.mts",
            "import": "./dist/file.mjs",
            "require": "./dist/file.cjs"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsdown && node scripts/generate-schema.js",
        "build:watch": "tsdown --watch",
        "build:schema": "node scripts/generate-schema.js",
        "clean": "rm -rf dist",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
        "test": "vitest run",
        "docs": "typedoc"
    },
    "dependencies": {
        "@cmtx/core": "workspace:*",
        "@cmtx/storage": "workspace:*",
        "@cmtx/template": "workspace:*",
        "js-yaml": "^4.1.0",
        "p-limit": "^7.3.0",
        "tinyglobby": "^0.2.0",
        "trash": "^10.1.0"
    },
    "devDependencies": {
        "@types/node": "^25.2.1",
        "ajv": "8.20.0",
        "dotenv": "^17.2.4",
        "ts-json-schema-generator": "2.9.0",
        "typedoc": "^0.28.16",
        "typescript": "^6.0.3",
        "vitest": "^4.0.18"
    },
    "engines": {
        "node": ">=22.0.0"
    }
}
