{
    "name": "@cmtx/publish",
    "version": "0.1.1-alpha.1",
    "description": "Markdown document processing — rule engine, content transformation, metadata management, and cross-platform adaptation",
    "keywords": [
        "cmtx",
        "content-transformation",
        "frontmatter",
        "markdown",
        "metadata",
        "publish",
        "rule-engine"
    ],
    "homepage": "https://github.com/cc01cc/cmtx-project/tree/main/packages/publish",
    "bugs": {
        "url": "https://github.com/cc01cc/cmtx-project/issues"
    },
    "license": "Apache-2.0",
    "author": "cc01cc",
    "repository": {
        "type": "git",
        "url": "https://github.com/cc01cc/cmtx-project.git",
        "directory": "packages/publish"
    },
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md"
    ],
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./node": {
            "types": "./dist/node.d.ts",
            "import": "./dist/node.mjs",
            "require": "./dist/node.cjs"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsdown",
        "build:watch": "tsdown --watch",
        "clean": "rm -rf dist",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
        "test": "vitest run",
        "docs": "typedoc"
    },
    "dependencies": {
        "@cmtx/asset": "workspace:*",
        "@cmtx/autocorrect-wasm": "workspace:*",
        "@cmtx/core": "workspace:*",
        "@cmtx/fpe-wasm": "workspace:*",
        "@cmtx/storage": "0.1.1-alpha.1",
        "@cmtx/template": "workspace:*",
        "js-yaml": "catalog:cli",
        "rehype-raw": "^7.0.0",
        "rehype-stringify": "^10.0.1",
        "remark-gfm": "^4.0.1",
        "remark-parse": "^11.0.0",
        "remark-rehype": "^11.1.2",
        "tinyglobby": "catalog:",
        "unified": "^11.0.5"
    },
    "devDependencies": {
        "@types/js-yaml": "catalog:cli",
        "@types/node": "catalog:",
        "typedoc": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    },
    "optionalDependencies": {
        "@cmtx/fpe-wasm": "workspace:*"
    },
    "engines": {
        "node": ">=22.0.0"
    }
}
