{
    "name": "@cmtx/markdown-it-presigned-url",
    "version": "0.1.1-alpha.3",
    "description": "Markdown-it plugin for presigned URL image rendering",
    "keywords": [
        "cmtx",
        "image",
        "markdown-it",
        "oss",
        "plugin",
        "presigned-url",
        "s3"
    ],
    "homepage": "https://github.com/cc01cc/cmtx-project",
    "bugs": {
        "url": "https://github.com/cc01cc/cmtx-project/issues"
    },
    "license": "Apache-2.0",
    "author": "cc01cc",
    "repository": {
        "type": "git",
        "url": "https://github.com/cc01cc/cmtx-project.git",
        "directory": "packages/markdown-it-presigned-url"
    },
    "files": [
        "dist",
        "README.md",
        "README.en.md",
        "CHANGELOG.md"
    ],
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "prepare": "pnpm build",
        "build": "tsdown",
        "build:watch": "tsdown --watch",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
        "test": "vitest run",
        "docs": "typedoc",
        "clean": "rimraf dist"
    },
    "dependencies": {},
    "devDependencies": {
        "@types/markdown-it": "^14.1.2",
        "@types/node": "^25.2.1",
        "@vitest/coverage-v8": "^4.0.18",
        "markdown-it": "^14.1.0",
        "typedoc": "^0.28.16",
        "typescript": "^6.0.3",
        "vitest": "^4.0.18"
    },
    "peerDependencies": {
        "markdown-it": "^14.0.0"
    },
    "engines": {
        "node": ">=22.0.0"
    }
}
