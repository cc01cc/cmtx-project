{
    "name": "@cmtx/mcp-server",
    "version": "0.2.0-alpha.1",
    "private": false,
    "description": "MCP-style stdio server for CMTX tools",
    "keywords": [
        "cmtx",
        "image",
        "markdown",
        "mcp"
    ],
    "homepage": "https://github.com/cc01cc/cmtx-project/tree/main/packages/mcp-server",
    "bugs": {
        "url": "https://github.com/cc01cc/cmtx-project/issues"
    },
    "license": "Apache-2.0",
    "author": "cc01cc",
    "repository": {
        "type": "git",
        "url": "https://github.com/cc01cc/cmtx-project.git",
        "directory": "packages/mcp-server"
    },
    "bin": {
        "cmtx-mcp": "./dist/server.mjs"
    },
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md"
    ],
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
        "test": "vitest run",
        "test:watch": "vitest",
        "clean": "rimraf dist"
    },
    "dependencies": {
        "@cmtx/asset": "workspace:*",
        "@cmtx/core": "workspace:*",
        "@cmtx/rule-engine": "workspace:*",
        "ali-oss": "^6.23.0"
    },
    "devDependencies": {
        "@types/ali-oss": "^6.23.2",
        "@types/node": "^25.2.1",
        "typescript": "^6.0.3",
        "vitest": "^4.0.18"
    },
    "engines": {
        "node": ">=22.0.0"
    }
}
