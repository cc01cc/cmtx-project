{
    "name": "@cmtx/cli",
    "version": "0.1.0",
    "private": true,
    "description": "Command line interface for Markdown image management",
    "keywords": [
        "cli",
        "cmtx",
        "image",
        "markdown",
        "upload"
    ],
    "homepage": "https://github.com/cc01cc/cmtx-project/tree/main/packages/cli",
    "bugs": {
        "url": "https://github.com/cc01cc/cmtx-project/issues"
    },
    "license": "Apache-2.0",
    "author": "cc01cc",
    "repository": {
        "type": "git",
        "url": "https://github.com/cc01cc/cmtx-project.git",
        "directory": "packages/cli"
    },
    "bin": {
        "cmtx": "./dist/cli.mjs"
    },
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md"
    ],
    "type": "module",
    "main": "./dist/index.cjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
        "test": "vitest run",
        "test:watch": "vitest",
        "clean": "rimraf dist"
    },
    "dependencies": {
        "@cmtx/asset": "workspace:*",
        "@cmtx/core": "workspace:*",
        "@cmtx/publish": "workspace:*",
        "ali-oss": "catalog:",
        "chalk": "catalog:cli",
        "ora": "catalog:cli",
        "winston": "^3.18.3",
        "winston-daily-rotate-file": "^5.0.0",
        "yargs": "catalog:cli"
    },
    "devDependencies": {
        "@types/ali-oss": "catalog:",
        "@types/node": "catalog:",
        "@types/yargs": "catalog:cli",
        "rimraf": "catalog:dev",
        "typescript": "catalog:",
        "vitest": "catalog:"
    },
    "engines": {
        "node": ">=22.0.0"
    }
}
