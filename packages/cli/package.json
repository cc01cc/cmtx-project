{
    "name": "@cmtx/cli",
    "version": "0.1.0",
    "description": "Command line interface for Markdown image management",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "main": "./dist/index.cjs",
    "types": "./dist/index.d.ts",
    "bin": {
        "cmtx": "./dist/cli.mjs"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "biome check --write src tests",
        "clean": "rimraf dist"
    },
    "dependencies": {
        "@cmtx/publish": "workspace:*",
        "@cmtx/core": "workspace:*",
        "@cmtx/asset": "workspace:*",
        "ali-oss": "catalog:",
        "chalk": "catalog:cli",
        "ora": "catalog:cli",
        "yargs": "catalog:cli"
    },
    "devDependencies": {
        "@types/ali-oss": "catalog:",
        "rimraf": "catalog:dev",
        "@types/node": "catalog:",
        "@types/yargs": "catalog:cli",
        "typescript": "catalog:",
        "vitest": "catalog:"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "keywords": [
        "markdown",
        "image",
        "upload",
        "cli"
    ],
    "license": "Apache-2.0"
}
