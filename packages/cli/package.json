{
  "name": "@cmtx/cli",
  "version": "0.0.1-dev",
  "description": "Command line interface for Markdown image management",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cmtx": "./dist/bin/cmtx.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@cmtx/core": "workspace:*",
    "@cmtx/upload": "workspace:*",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "yargs": "^17.7.2",
    "ali-oss": "^6.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/yargs": "^17.0.31",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "markdown",
    "image",
    "upload",
    "cli"
  ],
  "license": "Apache-2.0"
}
