{
  "name": "@cmtx/cli",
  "version": "0.0.1-dev",
  "description": "Command line interface for Markdown image management",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cmtx": "./dist/bin/cmtx.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@cmtx/core": "workspace:*",
    "@cmtx/upload": "workspace:*",
    "ali-oss": "^6.23.0",
    "chalk": "^5.6.2",
    "js-yaml": "4.1.1",
    "ora": "^9.2.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "@types/node": "^25.2.0",
    "@types/yargs": "^17.0.35",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "markdown",
    "image",
    "upload",
    "cli"
  ],
  "license": "Apache-2.0"
}
