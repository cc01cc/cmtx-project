{
    "name": "@cmtx/storage",
    "version": "0.1.1-alpha.2",
    "description": "Object storage adapters for cmtx",
    "keywords": [
        "cloud-storage",
        "cmtx",
        "cos",
        "oss",
        "s3",
        "storage"
    ],
    "homepage": "https://github.com/cc01cc/cmtx-project",
    "bugs": {
        "url": "https://github.com/cc01cc/cmtx-project/issues"
    },
    "license": "Apache-2.0",
    "author": "cc01cc",
    "repository": {
        "type": "git",
        "url": "https://github.com/cc01cc/cmtx-project.git",
        "directory": "packages/storage"
    },
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md"
    ],
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./adapters/ali-oss": {
            "types": "./dist/adapters/ali-oss.d.mts",
            "import": "./dist/adapters/ali-oss.mjs",
            "require": "./dist/adapters/ali-oss.cjs"
        },
        "./adapters/tencent-cos": {
            "types": "./dist/adapters/tencent-cos.d.mts",
            "import": "./dist/adapters/tencent-cos.mjs",
            "require": "./dist/adapters/tencent-cos.cjs"
        },
        "./adapters/factory": {
            "types": "./dist/adapters/factory.d.mts",
            "import": "./dist/adapters/factory.mjs",
            "require": "./dist/adapters/factory.cjs"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsdown",
        "build:watch": "tsdown --watch",
        "clean": "rm -rf dist",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
        "test": "vitest run",
        "test:integration": "vitest run --config vitest.integration.config.ts",
        "test:integration:oss": "vitest run --config vitest.integration.config.ts tests/integration/ali-oss.integration.test.ts",
        "test:integration:cos": "vitest run --config vitest.integration.config.ts tests/integration/tencent-cos.integration.test.ts",
        "docs": "typedoc"
    },
    "devDependencies": {
        "@types/ali-oss": "^6.23.2",
        "@types/node": "^25.2.1",
        "ali-oss": "^6.23.0",
        "cos-nodejs-sdk-v5": "^2.14.0",
        "typedoc": "^0.28.16",
        "typescript": "^6.0.3",
        "vitest": "^4.0.18"
    },
    "peerDependencies": {
        "ali-oss": "^6.23.0",
        "cos-nodejs-sdk-v5": "^2.14.0"
    },
    "peerDependenciesMeta": {
        "ali-oss": {
            "optional": true
        },
        "cos-nodejs-sdk-v5": {
            "optional": true
        }
    },
    "engines": {
        "node": ">=22.0.0"
    }
}
