# 阿里云 OSS 配置示例
# 复制此文件为 .env 并填入真实凭证

# OSS 区域（如 oss-cn-hangzhou, oss-cn-shanghai）
# 支持的区域列表：https://help.aliyun.com/document_detail/31837.html
ALIYUN_OSS_REGION=oss-cn-hangzhou

# AccessKey ID（在阿里云控制台获取）
# 获取路径：阿里云控制台 -> AccessKey管理 -> 创建AccessKey
ALIYUN_OSS_ACCESS_KEY_ID=your-access-key-id

# AccessKey Secret（在阿里云控制台获取）
# 注意：请妥善保管，不要泄露给他人
ALIYUN_OSS_ACCESS_KEY_SECRET=your-access-key-secret

# Bucket 名称
# 需要在OSS控制台提前创建好对应的Bucket
ALIYUN_OSS_BUCKET=your-bucket-name

# 注意事项：
# 1. 请确保AccessKey具有对应Bucket的读写权限
# 2. Bucket需要开启公共读权限才能通过URL直接访问
# 3. 建议使用RAM用户创建专用的AccessKey，而不是主账号