{
    "name": "cmtx-vscode",
    "displayName": "CMTX for VS Code",
    "version": "0.1.1",
    "private": true,
    "description": "Markdown Toolkit",
    "categories": [
        "Formatters",
        "Other",
        "Programming Languages"
    ],
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/cc01cc/cmtx-project"
    },
    "publisher": "cc01cc",
    "type": "module",
    "main": "./dist/extension.cjs",
    "scripts": {
        "build": "tsdown",
        "build:test": "tsc -p tsconfig.test.json",
        "watch": "tsdown --watch",
        "package": "pnpm run build && node scripts/package.mjs",
        "package:dev": "pnpm run build && node scripts/package.mjs dev",
        "package:prod": "pnpm run build && node scripts/package.mjs prod",
        "package:stable": "pnpm run build && node scripts/package.mjs stable",
        "package:pre-release": "pnpm run build && node scripts/package.mjs prerelease",
        "publish:pre-release": "vsce publish --no-dependencies --pre-release",
        "publish:stable": "vsce publish --no-dependencies",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
        "test": "vitest run",
        "test:unit": "vitest run tests/unit",
        "test:coverage": "vitest run --coverage",
        "test:integration": "pnpm build:test && node dist/test/test/runTest.js",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@cmtx/asset": "workspace:*",
        "@cmtx/core": "workspace:*",
        "@cmtx/fpe-wasm": "workspace:*",
        "@cmtx/markdown-it-presigned-url": "workspace:*",
        "@cmtx/markdown-it-presigned-url-adapter-nodejs": "workspace:*",
        "@cmtx/publish": "workspace:*",
        "@cmtx/storage": "workspace:*",
        "ali-oss": "catalog:",
        "tinyglobby": "catalog:",
        "trash": "catalog:"
    },
    "devDependencies": {
        "@types/ali-oss": "catalog:",
        "@types/mocha": "10.0.10",
        "@types/node": "catalog:",
        "@types/sinon": "21.0.1",
        "@types/vscode": "1.103.0",
        "@vscode/test-electron": "2.5.2",
        "@vscode/vsce": "^3.9.1",
        "mocha": "11.7.5",
        "patch-package": "8.0.1",
        "rolldown-plugin-wasm": "0.2.1",
        "sinon": "21.0.3",
        "tsdown": "0.21.10",
        "typescript": "catalog:",
        "vitest": "catalog:"
    },
    "optionalDependencies": {
        "proxy-agent": "^8.0.1"
    },
    "contributes": {
        "commands": [
            {
                "command": "cmtx.uploadSelected",
                "title": "Upload selected images",
                "category": "CMTX"
            },
            {
                "command": "cmtx.download",
                "title": "Download remote images",
                "category": "CMTX"
            },
            {
                "command": "cmtx.formatToHtml",
                "title": "Convert images to HTML format",
                "category": "CMTX"
            },
            {
                "command": "cmtx.setImageWidth",
                "title": "Set image width...",
                "category": "CMTX"
            },
            {
                "command": "cmtx.zoomIn",
                "title": "Increase image size (zoom in)",
                "category": "CMTX"
            },
            {
                "command": "cmtx.zoomOut",
                "title": "Decrease image size (zoom out)",
                "category": "CMTX"
            },
            {
                "command": "cmtx.applyPreset",
                "title": "Apply preset...",
                "category": "CMTX"
            },
            {
                "command": "cmtx.configInit",
                "title": "Create configuration...",
                "category": "CMTX"
            },
            {
                "command": "cmtx.clearPresignedCache",
                "title": "Clear presigned URL cache",
                "category": "CMTX"
            },
            {
                "command": "cmtx.deleteImage",
                "title": "Delete image...",
                "category": "CMTX"
            },
            {
                "command": "cmtx.refreshConfig",
                "title": "Refresh configuration (reload window to apply)",
                "category": "CMTX"
            },
            {
                "command": "cmtx.reloadWindow",
                "title": "Reload window to apply config changes",
                "category": "CMTX"
            },
            {
                "command": "cmtx.addSectionNumbers",
                "title": "Add/Update section numbers",
                "category": "CMTX"
            },
            {
                "command": "cmtx.removeSectionNumbers",
                "title": "Remove section numbers",
                "category": "CMTX"
            },
            {
                "command": "cmtx.rule.upload-images",
                "title": "Upload images",
                "category": "CMTX"
            },
            {
                "command": "cmtx.rule.frontmatter-id",
                "title": "Generate frontmatter ID",
                "category": "CMTX"
            },
            {
                "command": "cmtx.rule.frontmatter-title",
                "title": "Convert title to frontmatter",
                "category": "CMTX"
            },
            {
                "command": "cmtx.rule.strip-frontmatter",
                "title": "Strip frontmatter",
                "category": "CMTX"
            },
            {
                "command": "cmtx.rule.promote-headings",
                "title": "Promote headings",
                "category": "CMTX"
            },
            {
                "command": "cmtx.rule.add-section-numbers",
                "title": "Add section numbers",
                "category": "CMTX"
            },
            {
                "command": "cmtx.rule.remove-section-numbers",
                "title": "Remove section numbers",
                "category": "CMTX"
            },
            {
                "command": "cmtx.rule.convert-images",
                "title": "Convert images to HTML",
                "category": "CMTX"
            },
            {
                "command": "cmtx.rule.frontmatter-date",
                "title": "Add frontmatter date",
                "category": "CMTX"
            },
            {
                "command": "cmtx.rule.frontmatter-updated",
                "title": "Add frontmatter updated date",
                "category": "CMTX"
            },
            {
                "command": "cmtx.rule.download-images",
                "title": "Download remote images",
                "category": "CMTX"
            },
            {
                "command": "cmtx.rule.delete-image",
                "title": "Delete image",
                "category": "CMTX"
            },
            {
                "command": "cmtx.rule.resize-image",
                "title": "Resize image",
                "category": "CMTX"
            }
        ],
        "submenus": [
            {
                "id": "cmtx.submenu",
                "label": "CMTX",
                "icon": "$(file-media)"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "submenu": "cmtx.submenu",
                    "when": "editorLangId == markdown",
                    "group": "9_cmtx@1"
                }
            ],
            "cmtx.submenu": [
                {
                    "command": "cmtx.uploadSelected",
                    "when": "editorLangId == markdown && editorHasSelection",
                    "group": "upload@1"
                },
                {
                    "command": "cmtx.setImageWidth",
                    "when": "editorLangId == markdown && editorHasSelection",
                    "group": "resize@1"
                },
                {
                    "command": "cmtx.zoomIn",
                    "when": "editorLangId == markdown && editorHasSelection",
                    "group": "resize@2"
                },
                {
                    "command": "cmtx.zoomOut",
                    "when": "editorLangId == markdown && editorHasSelection",
                    "group": "resize@3"
                },
                {
                    "command": "cmtx.formatToHtml",
                    "when": "editorLangId == markdown && editorHasSelection",
                    "group": "format@1"
                },
                {
                    "command": "cmtx.applyPreset",
                    "when": "editorLangId == markdown",
                    "group": "preset@1"
                }
            ]
        },
        "keybindings": [
            {
                "command": "cmtx.formatToHtml",
                "key": "ctrl+shift+h",
                "when": "editorLangId == markdown"
            },
            {
                "command": "cmtx.zoomIn",
                "key": "ctrl+up",
                "when": "editorLangId == markdown && editorHasSelection"
            },
            {
                "command": "cmtx.zoomOut",
                "key": "ctrl+down",
                "when": "editorLangId == markdown && editorHasSelection"
            }
        ],
        "configuration": {
            "title": "CMTX",
            "properties": {
                "cmtx.configDir": {
                    "type": "string",
                    "default": ".cmtx",
                    "description": "CMTX configuration directory path. Relative to workspace folder or absolute path. All other CMTX settings are configured in .cmtx/config.yaml"
                }
            }
        },
        "markdown.markdownItPlugins": true
    },
    "activationEvents": [
        "onLanguage:markdown",
        "onStartupFinished"
    ],
    "extensionKind": [
        "workspace"
    ],
    "icon": "assets/logo-white-background.png",
    "engines": {
        "vscode": "^1.110.0"
    }
}
