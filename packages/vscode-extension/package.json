{
    "name": "cmtx-vscode",
    "displayName": "CMTX for VS Code",
    "description": "Markdown Toolkit",
    "version": "0.1.0",
    "publisher": "cc01cc",
    "engines": {
        "vscode": "^1.103.0"
    },
    "icon": "assets/logo-white-background.png",
    "extensionKind": [
        "workspace"
    ],
    "activationEvents": [
        "onStartupFinished",
        "onLanguage:markdown"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/cc01cc/cmtx-project"
    },
    "main": "./dist/extension.js",
    "files": [
        "dist/extension.js",
        "dist/node_modules/**",
        "assets/**",
        "README.md",
        "CHANGELOG.md",
        "LICENSE"
    ],
    "contributes": {
        "commands": [
            {
                "command": "cmtx.upload",
                "title": "Upload local images",
                "category": "CMTX"
            },
            {
                "command": "cmtx.uploadSelected",
                "title": "Upload selected images",
                "category": "CMTX"
            },
            {
                "command": "cmtx.download",
                "title": "Download remote images",
                "category": "CMTX"
            },
            {
                "command": "cmtx.formatToHtml",
                "title": "Convert images to HTML format",
                "category": "CMTX"
            },
            {
                "command": "cmtx.formatToMarkdown",
                "title": "Convert images to Markdown format",
                "category": "CMTX"
            },
            {
                "command": "cmtx.setImageWidth",
                "title": "Set image width...",
                "category": "CMTX"
            },
            {
                "command": "cmtx.zoomIn",
                "title": "Increase image size (zoom in)",
                "category": "CMTX"
            },
            {
                "command": "cmtx.zoomOut",
                "title": "Decrease image size (zoom out)",
                "category": "CMTX"
            },
            {
                "command": "cmtx.applyPreset",
                "title": "Apply preset...",
                "category": "CMTX"
            },
            {
                "command": "cmtx.applyRule",
                "title": "Apply rule...",
                "category": "CMTX"
            },
            {
                "command": "cmtx.analyze",
                "title": "Analyze document images",
                "category": "CMTX"
            },
            {
                "command": "cmtx.findReferences",
                "title": "Find image references",
                "category": "CMTX"
            },
            {
                "command": "cmtx.configInit",
                "title": "Create configuration...",
                "category": "CMTX"
            },
            {
                "command": "cmtx.configEdit",
                "title": "Edit configuration file",
                "category": "CMTX"
            },
            {
                "command": "cmtx.configUI",
                "title": "Open configuration UI",
                "category": "CMTX"
            },
            {
                "command": "cmtx.clearPresignedCache",
                "title": "Clear presigned URL cache",
                "category": "CMTX"
            },
            {
                "command": "cmtx.deleteImage",
                "title": "Delete image...",
                "category": "CMTX"
            },
            {
                "command": "cmtx.refreshConfig",
                "title": "Refresh configuration (reload window to apply)",
                "category": "CMTX"
            },
            {
                "command": "cmtx.reloadWindow",
                "title": "Reload window to apply config changes",
                "category": "CMTX"
            },
            {
                "command": "cmtx.addSectionNumbers",
                "title": "Add/Update section numbers",
                "category": "CMTX"
            },
            {
                "command": "cmtx.removeSectionNumbers",
                "title": "Remove section numbers",
                "category": "CMTX"
            }
        ],
        "submenus": [
            {
                "id": "cmtx.submenu",
                "label": "CMTX",
                "icon": "$(file-media)"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "submenu": "cmtx.submenu",
                    "when": "editorLangId == markdown",
                    "group": "9_cmtx@1"
                }
            ],
            "cmtx.submenu": [
                {
                    "command": "cmtx.uploadSelected",
                    "when": "editorLangId == markdown && editorHasSelection",
                    "group": "upload@1"
                },
                {
                    "command": "cmtx.setImageWidth",
                    "when": "editorLangId == markdown && editorHasSelection",
                    "group": "resize@1"
                },
                {
                    "command": "cmtx.zoomIn",
                    "when": "editorLangId == markdown && editorHasSelection",
                    "group": "resize@2"
                },
                {
                    "command": "cmtx.zoomOut",
                    "when": "editorLangId == markdown && editorHasSelection",
                    "group": "resize@3"
                },
                {
                    "command": "cmtx.findReferences",
                    "when": "editorLangId == markdown",
                    "group": "reference@1"
                },
                {
                    "command": "cmtx.formatToHtml",
                    "when": "editorLangId == markdown && editorHasSelection",
                    "group": "format@1"
                },
                {
                    "command": "cmtx.formatToMarkdown",
                    "when": "editorLangId == markdown && editorHasSelection",
                    "group": "format@2"
                },
                {
                    "command": "cmtx.applyPreset",
                    "when": "editorLangId == markdown",
                    "group": "preset@1"
                },
                {
                    "command": "cmtx.applyRule",
                    "when": "editorLangId == markdown",
                    "group": "rule@1"
                }
            ]
        },
        "keybindings": [
            {
                "command": "cmtx.formatToHtml",
                "key": "ctrl+shift+h",
                "when": "editorLangId == markdown"
            },
            {
                "command": "cmtx.zoomIn",
                "key": "ctrl+up",
                "when": "editorLangId == markdown && editorHasSelection"
            },
            {
                "command": "cmtx.zoomOut",
                "key": "ctrl+down",
                "when": "editorLangId == markdown && editorHasSelection"
            }
        ],
        "configuration": {
            "title": "CMTX",
            "properties": {
                "cmtx.configDir": {
                    "type": "string",
                    "default": ".cmtx",
                    "description": "CMTX configuration directory path. Relative to workspace folder or absolute path. All other CMTX settings are configured in .cmtx/config.yaml"
                }
            }
        },
        "markdown.markdownItPlugins": true
    },
    "scripts": {
        "build": "node esbuild.config.mjs && node scripts/copy-wasm.mjs && node scripts/verify-build.mjs",
        "build:test": "tsc -p tsconfig.test.json",
        "watch": "node esbuild.config.mjs --watch",
        "package": "npm run build && node scripts/package.mjs",
        "package:dev": "npm run build && node scripts/package.mjs dev",
        "package:prod": "npm run build && node scripts/package.mjs prod",
        "package:stable": "npm run build && node scripts/package.mjs stable",
        "package:prerelease": "npm run build && node scripts/package.mjs prerelease",
        "publish:prerelease": "vsce publish --pre-release",
        "publish:stable": "vsce publish",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
        "lint": "biome check src --fix",
        "test": "vitest run",
        "test:unit": "vitest run tests/unit",
        "test:coverage": "vitest run --coverage",
        "test:integration": "pnpm build:test && node dist/test/test/runTest. js",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@cmtx/asset": "workspace:*",
        "@cmtx/core": "workspace:*",
        "@cmtx/markdown-it-presigned-url": "workspace:*",
        "@cmtx/markdown-it-presigned-url-adapter-nodejs": "workspace:*",
        "@cmtx/publish": "workspace:*",
        "@cmtx/storage": "workspace:*",
        "ali-oss": "catalog:",
        "trash": "catalog:"
    },
    "devDependencies": {
        "@cmtx/fpe-wasm": "workspace:*",
        "@types/ali-oss": "catalog:",
        "@types/mocha": "10.0.10",
        "@types/node": "catalog:",
        "@types/sinon": "21.0.1",
        "@types/vscode": "^1.103.0",
        "@vscode/test-electron": "2.5.2",
        "@vscode/vsce": "^3.9.1",
        "esbuild": "catalog:",
        "mocha": "11.7.5",
        "sinon": "21.0.3",
        "typescript": "catalog:",
        "vitest": "catalog:"
    },
    "license": "Apache-2.0"
}