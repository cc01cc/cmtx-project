{
    "entryPoints": ["src/index.ts"],
    "out": "docs/api",
    "exclude": ["**/*.test.ts", "**/*.spec.ts"],
    "plugin": [],
    "readme": "README.md",
    "name": "cmtx-core",
    "includeVersion": true,
    "tsconfig": "tsconfig.typedoc.json",
    "excludeReferences": true,
    "excludeInternal": true,
    "categoryOrder": [
        "图片筛选",
        "图片替换",
        "图片删除",
        "图片解析",
        "元数据处理",
        "多正则操作",
        "日志",
        "监控",
        "工具函数",
        "常量",
        "核心类型",
        "图片匹配",
        "筛选类型",
        "替换类型",
        "删除类型",
        "错误处理",
        "多正则类型",
        "元数据类型",
        "*"
    ],
    "blockTags": [
        "@public",
        "@internal",
        "@private",
        "@note",
        "@param",
        "@returns",
        "@remarks",
        "@example",
        "@see",
        "@throws",
        "@module",
        "@category"
    ],
    "externalSymbolLinkMappings": {
        "@types/node": {
            "__global.module": "#"
        }
    }
}
