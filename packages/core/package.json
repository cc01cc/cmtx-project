{
    "name": "@cmtx/core",
    "version": "0.4.0-alpha.3",
    "description": "Core markdown document processing library - image extraction/manipulation and metadata handling",
    "keywords": [
        "cmtx",
        "extract",
        "frontmatter",
        "images",
        "markdown",
        "metadata",
        "replace"
    ],
    "homepage": "https://github.com/cc01cc/cmtx-project",
    "bugs": {
        "url": "https://github.com/cc01cc/cmtx-project/issues"
    },
    "license": "Apache-2.0",
    "author": "cc01cc",
    "repository": {
        "type": "git",
        "url": "https://github.com/cc01cc/cmtx-project.git",
        "directory": "packages/core"
    },
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md"
    ],
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsdown",
        "build:watch": "tsdown --watch",
        "clean": "rm -rf dist",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
        "test": "vitest run",
        "docs": "typedoc"
    },
    "dependencies": {
        "js-yaml": "4.1.1"
    },
    "devDependencies": {
        "@types/js-yaml": "4.0.9",
        "@types/node": "^25.2.1",
        "@vitest/coverage-v8": "^4.0.18",
        "typedoc": "^0.28.16",
        "typescript": "^6.0.3",
        "vitest": "^4.0.18"
    },
    "engines": {
        "node": ">=22.0.0"
    }
}
