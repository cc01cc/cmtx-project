{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "stripInternal": true
  },
  "include": ["src/**/*"],
  "exclude": ["tests", "**/*.test.ts", "dist"]
}
