{
    "name": "@cmtx/markdown-it-presigned-url-adapter-nodejs",
    "version": "0.2.0-alpha.3",
    "description": "Node.js adapter for markdown-it presigned URL plugin",
    "keywords": [
        "adapter",
        "cmtx",
        "image",
        "markdown-it",
        "presigned-url"
    ],
    "homepage": "https://github.com/cc01cc/cmtx-project/tree/main/packages/markdown-it-presigned-url-adapter-nodejs",
    "bugs": {
        "url": "https://github.com/cc01cc/cmtx-project/issues"
    },
    "license": "Apache-2.0",
    "author": "cc01cc",
    "repository": {
        "type": "git",
        "url": "https://github.com/cc01cc/cmtx-project.git",
        "directory": "packages/markdown-it-presigned-url-adapter-nodejs"
    },
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md"
    ],
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "prepare": "pnpm build",
        "build": "tsdown",
        "build:watch": "tsdown --watch",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "test": "vitest run --passWithNoTests",
        "docs": "typedoc",
        "clean": "rimraf dist"
    },
    "dependencies": {
        "@cmtx/core": "workspace:*",
        "@cmtx/storage": "workspace:*",
        "ali-oss": "^6.23.0"
    },
    "devDependencies": {
        "@types/ali-oss": "^6.23.2",
        "@types/node": "^25.2.1",
        "typescript": "^6.0.3",
        "vitest": "^4.0.18"
    },
    "peerDependencies": {
        "@cmtx/markdown-it-presigned-url": "workspace:*"
    },
    "engines": {
        "node": ">=22.0.0"
    }
}
